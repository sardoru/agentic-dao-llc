{
  "name": "agentic-dao-llc",
  "version": "0.1.0",
  "private": true,
  "description": "Agentically-Governed DAO LLC — AI agents holding delegated voting power govern a Wyoming DAO LLC on-chain, bounded by one mandate enforced in three layers (contracts, runtime, legal).",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "gen:reserved": "node scripts/gen-reserved-matters.mjs",
    "check:reserved": "node scripts/gen-reserved-matters.mjs --check",
    "build": "pnpm -r --filter \"./packages/*\" build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "contracts:build": "forge build --root contracts",
    "contracts:test": "forge test --root contracts -vvv",
    "e2e:local": "node scripts/e2e-local.mjs",
    "verify": "pnpm check:reserved && pnpm lint && pnpm typecheck && pnpm build && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "viem": "^2.21.55",
    "vitest": "^2.1.8",
    "yaml": "^2.6.1"
  }
}
