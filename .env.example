# ─────────────────────────────────────────────────────────────────────────────
# Agentic DAO LLC — environment template.  TESTNET ONLY.
# Copy to .env and fill. NEVER commit a real secret, mainnet key, or real funds.
# ─────────────────────────────────────────────────────────────────────────────

# Chain — Base Sepolia by default (swappable: Arbitrum/Optimism Sepolia)
RPC_URL=https://sepolia.base.org
CHAIN_ID=84532

# Deployed addresses (filled after Phase 1/2 deploy)
MEMBERSHIP_TOKEN=
GOVERNOR=
TIMELOCK=
AGENT_REGISTRY=
ROLES_MODIFIER=
TREASURY_SAFE=
GUARDIAN_SAFE=
RATIONALE_ANCHOR=

# Simulation — Tenderly primary, anvil-fork fallback
TENDERLY_ACCOUNT=
TENDERLY_PROJECT=
TENDERLY_ACCESS_KEY=
ANVIL_FORK_RPC_URL=https://sepolia.base.org

# IPFS — rationale + mandate docs
IPFS_PROVIDER=pinata          # pinata | web3storage
IPFS_TOKEN=
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# Signer — DEV ONLY local keystore. Prod uses Turnkey/KMS behind the Signer iface.
# Mainnet is GATED on the hardened signer (see docs/threat-model.md).
SIGNER_BACKEND=local          # local | turnkey | kms
SIGNER_KEYSTORE_PATH=./.keystore/agent.json
SIGNER_KEYSTORE_PASSWORD=
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
TURNKEY_ORGANIZATION_ID=

# Indexer (Ponder)
PONDER_RPC_URL_84532=https://sepolia.base.org
PONDER_DATABASE_URL=          # empty = pglite (local dev)

# Dashboard
NEXT_PUBLIC_INDEXER_URL=http://localhost:42069
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org

# Dashboard auth (SIWE wallet-connect login) — see docs/adr/0006-authentication.md
# REQUIRED in production: signs the session JWT cookie (min 16 chars). Dev uses an
# insecure built-in fallback if unset.
AUTH_SESSION_SECRET=
# Optional: enables the WalletConnect (mobile/QR) connector. Free id at https://cloud.reown.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Optional role resolution at login (defaults fall back to the chain vars above).
# The guardian address gates the guardian console's cancel button.
NEXT_PUBLIC_GUARDIAN_ADDRESS=
NEXT_PUBLIC_MEMBERSHIP_TOKEN_ADDRESS=
NEXT_PUBLIC_TIMELOCK_ADDRESS=
