{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-dao-llc/mandate.schema.json",
  "title": "Agent Mandate",
  "description": "Machine-readable policy bounding a delegated AI agent. Canonicalized (sorted keys, no insignificant whitespace) and keccak256-hashed; the hash is stored on-chain in AgentRegistry and mirrored in the legal exhibit. See build spec §7.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "agentId",
    "principal",
    "agentAccount",
    "scope",
    "requireSimulation",
    "rationaleStorage",
    "guardian",
    "createdAt",
    "expiresAt"
  ],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "agentId": { "type": "string", "minLength": 1 },
    "principal": { "$ref": "#/$defs/address", "description": "Human member who delegated." },
    "agentAccount": { "$ref": "#/$defs/address", "description": "Agent Safe / signer address." },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canPropose", "canVote", "proposalTypes", "allowedTargets"],
      "properties": {
        "canPropose": { "type": "boolean" },
        "canVote": { "type": "boolean" },
        "proposalTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "TREASURY_PAYMENT",
              "PARAM_TUNE_NONRESERVED",
              "TEXT_SIGNAL",
              "OPERATING_EXPENSE"
            ]
          },
          "uniqueItems": true
        },
        "allowedTargets": {
          "type": "array",
          "items": { "$ref": "#/$defs/address" },
          "uniqueItems": true
        },
        "forbiddenSelectors": {
          "type": "array",
          "items": { "$ref": "#/$defs/selector" },
          "uniqueItems": true,
          "description": "Extra denied selectors on top of the reserved set."
        },
        "spendingCap": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["token", "perTx", "perEpoch", "epochSeconds"],
          "properties": {
            "token": { "$ref": "#/$defs/address" },
            "perTx": { "$ref": "#/$defs/uint256" },
            "perEpoch": { "$ref": "#/$defs/uint256" },
            "epochSeconds": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "votingPolicy": {
      "type": "string",
      "description": "ipfs:// ref to a voting policy doc or model-prompt; how the agent decides its vote."
    },
    "humanRatification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "valueUsdGte": { "type": "number", "minimum": 0 },
        "impact": {
          "type": "array",
          "items": { "type": "string", "enum": ["LOW", "MED", "HIGH"] },
          "uniqueItems": true
        }
      },
      "description": "Above this value/impact, actions become draft-for-human rather than auto-submitted."
    },
    "requireSimulation": { "type": "boolean" },
    "rationaleStorage": { "type": "string", "enum": ["ipfs", "arweave"] },
    "guardian": { "$ref": "#/$defs/address" },
    "createdAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "address": { "type": "string", "pattern": "^0x[a-fA-F0-9]{40}$" },
    "selector": { "type": "string", "pattern": "^0x[a-fA-F0-9]{8}$" },
    "uint256": { "type": "string", "pattern": "^[0-9]+$" }
  },
  "examples": [
    {
      "version": "1.0",
      "agentId": "OPS-01",
      "principal": "0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC",
      "agentAccount": "0x14dC79964da2C08b23698B3D3cc7Ca32193d9955",
      "scope": {
        "canPropose": true,
        "canVote": false,
        "proposalTypes": ["OPERATING_EXPENSE", "TEXT_SIGNAL"],
        "allowedTargets": ["0x036CbD53842c5426634e7929541eC2318f3dCF7e"],
        "forbiddenSelectors": ["0x2f2ff15d", "0x64d62353", "0xb51e77d5"],
        "spendingCap": {
          "token": "0x036CbD53842c5426634e7929541eC2318f3dCF7e",
          "perTx": "500000000",
          "perEpoch": "2000000000",
          "epochSeconds": 604800
        }
      },
      "votingPolicy": "ipfs://bafyOPS01votingPolicyPLACEHOLDER",
      "humanRatification": { "valueUsdGte": 1000, "impact": ["HIGH"] },
      "requireSimulation": true,
      "rationaleStorage": "ipfs",
      "guardian": "0x70997970C51812dc3A010C7d01b50e0d17dc79C8",
      "createdAt": "2026-06-24T00:00:00Z",
      "expiresAt": "2026-09-24T00:00:00Z"
    }
  ]
}
