{
  "name": "@agentic-dao/mcp",
  "version": "0.1.0",
  "description": "Agent-facing MCP server: governance tools that are the policy chokepoint — no tool can construct an action the policy engine denies, no write without a prior simulation + pinned rationale (build spec §11).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentic-dao-mcp": "./dist/server.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentic-dao/chain": "workspace:*",
    "@agentic-dao/policy": "workspace:*",
    "@agentic-dao/signer": "workspace:*",
    "@agentic-dao/sim": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "viem": "^2.21.55",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
