{
  "name": "@agentic-dao/cli",
  "version": "0.1.0",
  "description": "Scriptable mirror of the MCP tools sharing the SAME policy/sim/signer/chain modules — the two must never diverge (build spec §12).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentic-dao": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentic-dao/chain": "workspace:*",
    "@agentic-dao/mcp": "workspace:*",
    "@agentic-dao/policy": "workspace:*",
    "@agentic-dao/signer": "workspace:*",
    "@agentic-dao/sim": "workspace:*",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "viem": "^2.21.55"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
